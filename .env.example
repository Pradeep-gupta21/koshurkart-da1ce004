# Required public env vars for the frontend (Vite exposes only VITE_* vars to the client).
# These are publishable keys — safe to commit/expose. Copy these into Vercel:
# Project → Settings → Environment Variables (Production, Preview, Development).

VITE_SUPABASE_URL="https://YOUR_SUPABASE_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY_HERE"
VITE_SUPABASE_PROJECT_ID="YOUR_SUPABASE_PROJECT_REF"
VITE_SUPPORT_WHATSAPP_NUMBER=REPLACE_WITH_WHATSAPP_NUMBER

# Gemini API key — consumed exclusively by the ai-chat Supabase Edge Function.
# NEVER set this as a VITE_ variable or Vercel frontend env var.
# Set it only as a Supabase secret: supabase secrets set GEMINI_API_KEY=<your-key>
# Obtain a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
